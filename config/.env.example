# ─────────────────────────────────────────────────────────────────────
# Globus — .env (root:globus 0640 on prod; .gitignored here)
#
# Only the BOOTSTRAP values live here (DB connection + Python paths
# for the OAuth callbacks). All runtime knobs (model picks, ElevenLabs
# agent ID, LLM provider, voice token TTL, etc.) live in the MySQL
# `config` table so they can be rotated without a restart.
#
# Read order in cfg(key, default):
#   1. MySQL `config` table  (preferred — DB-rotated, no deploy needed)
#   2. process env (.env)
#   3. the default arg
# ─────────────────────────────────────────────────────────────────────

# ---- MySQL connection (required) ----
# For `docker compose up`: leave DB_HOST=db (the compose service name).
# For a manual install: set DB_HOST=127.0.0.1 (or your MySQL host).
DB_HOST=db
DB_PORT=3306
DB_USER=globus
DB_PASSWORD=change-me
DB_NAME=globus
# Only used by the docker-compose `db` service for the root password
# (not used by the Globus app itself). Pick a different value here
# than DB_PASSWORD above.
DB_ROOT_PASSWORD=change-me-root

# ---- HTTP server bind (required) ----
GLOBUS_HOST=127.0.0.1
GLOBUS_PORT=8090
# Public-facing URL — used in OAuth callbacks + outbound email links.
SITE=https://example.com

# ---- Session secret (required, 32+ random bytes) ----
# Generate with: python3 -c 'import secrets; print(secrets.token_hex(32))'
SESSION_SECRET=replace-with-32-byte-hex

# ---- LLM provider (one of: claude-oauth | anthropic | deepseek) ----
# claude-oauth = local proxy at 127.0.0.1:8787 (zero per-token cost
#                via your Claude Max subscription). See
#                scripts/claude_oauth_proxy.md.
# anthropic    = direct Anthropic API (needs ANTHROPIC_API_KEY).
# deepseek     = OpenAI-compatible DeepSeek (needs DEEPSEEK_API_KEY).
GLOBUS_LLM_PROVIDER=claude-oauth
GLOBUS_OAUTH_MODEL=sonnet            # opus | sonnet | haiku
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ---- Email (required for OTP login) ----
# Default uses SendGrid. Plug any SMTP / API-based sender into
# server/members_auth_html.py if you prefer.
EMAIL_API_KEY=
EMAIL_FROM=hello@example.com

# ---- Google OAuth (optional — Drive + Gmail + Analytics sources) ----
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {SITE}/members/connect/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Microsoft OAuth (optional — MS Teams chat source via Graph API) ----
# Create at https://entra.microsoft.com/ (App registrations)
# Authorized redirect URI: {SITE}/members/connect/microsoft/callback
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# ---- Fernet encryption key for OAuth refresh tokens (REQUIRED if you
# enable any OAuth provider above) ----
# Generate with: python3 -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
GLOBUS_OAUTH_ENCRYPTION_KEY=

# ---- ElevenLabs (optional — voice path) ----
# See docs/voice-setup.md for full ElevenLabs Conversational AI setup.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_VOICE_ID=wDsJlOXPqcvIUKdLXjDs    # "Jarvis" — library voice
# HMAC secret for the custom-LLM endpoint (members voice). Generate
# with the same token_hex call; store identically in ElevenLabs
# workspace secrets.
GLOBUS_VOICE_LLM_SECRET=

# ---- Globus AI behaviour knobs (sensible defaults) ----
GLOBUS_DAILY_CAP=500            # user messages per UTC day per member
GLOBUS_MAX_CONNECTIONS_PER_MEMBER=10
GLOBUS_VAULT_MAX_CHARS=200000
# Directory the offline vault auto-builder writes notes into (read by the
# vault-progress dashboard). Defaults to /opt/globus/vault/auto.
GLOBUS_VAULT_AUTO_DIR=

# ---- Single-tenant owner (optional) ----
# Email of the member who may trigger/read the Hermes background agents in
# a single-tenant deploy. Leave blank to fall back to GLOBUS_FIRST_MEMBER_EMAIL;
# if both are blank, owner-only agents stay locked until you set one.
AGENTS_OWNER_EMAIL=

# ---- Docker compose helpers (only read by docker-compose.yml,
# not by the app itself) ----
# Host port that maps to container :8090. Change if 8090 is busy.
GLOBUS_PORT_EXPOSED=8090
# Optional: seed an initial member on first boot so /members/login
# works immediately. Leave blank to add members manually via SQL.
GLOBUS_FIRST_MEMBER_EMAIL=

# ---- Globus for Organizations (optional multi-tenant employee portals) ----
# Dormant unless you add an `organizations` row (see INSTALL.md). An org
# portal is served on its own Host; employees self-enroll with their company
# email and each chats over their OWN data only.
#
# Fail-closed host->slug fallback, consulted ONLY if the DB read of
# organizations.portal_host fails, so a recognised org host never falls
# through to the single-tenant site during a DB blip. Format:
#   'host:slug,host2:slug2'
ORG_PORTAL_HOSTS=
# Optional: a SEPARATE Google OAuth client for org sign-in / connect (distinct
# consent branding + blast radius). Falls back to GOOGLE_OAUTH_CLIENT_ID /
# _SECRET when unset.
ORG_GOOGLE_OAUTH_CLIENT_ID=
ORG_GOOGLE_OAUTH_CLIENT_SECRET=
# Show "Continue with Google" on the org login page (only if the tenant's IdP
# really is Google Workspace). Default off -> email one-time-code login.
ORG_GOOGLE_LOGIN_ENABLED=0
# Legal-page identity shown on the org privacy/terms pages (the Google consent
# screen links them). ORG_LEGAL_ENTITY blank -> the org's own name is used.
# ORG_LEGAL_CONTACT / ORG_LEGAL_UPDATED blank -> those lines are simply omitted
# rather than printing a placeholder. Have your own counsel review the wording.
ORG_LEGAL_CONTACT=
ORG_LEGAL_ENTITY=
ORG_LEGAL_UPDATED=

# ---- Email intelligence (optional two-tier inbox triage) ----
# Two cron'd passes over a CONNECTED Gmail mailbox: a cheap "triage" pass that
# files mail into your taxonomy, and a "reason" pass that reads the full body of
# only what triage couldn't recognise and records a judgment. Neither can
# archive or delete mail — labels are added, never removed. See
# server/email_intel.py and INSTALL.md.
#
# THE most important setting here. A free-text paragraph: what your business is,
# who matters, what counts as urgent. Ships EMPTY on purpose — with no context
# the reasoner flags plausible noise and misses what matters. Write this first.
EMAIL_INTEL_CONTEXT=
# Tier-1 buckets, as JSON [{"name","description"}]. Unset = a generic default
# set. Keep it SMALL and mutually exclusive: a flat taxonomy a cheap model
# applies consistently beats a rich one it applies differently every run.
EMAIL_INTEL_TAXONOMY=
# Optional deterministic From-domain rules, JSON [["example.com","Newsletter"]].
# Checked before the model: cheaper, always right, and consistently spelled.
EMAIL_INTEL_SENDER_RULES=
# The single label the reasoner may apply when something needs action.
EMAIL_INTEL_ACTION_LABEL=Action-Needed
# Mailboxes the digest reports on (comma-separated). Must match the mailboxes
# your reason crons actually cover, or the digest reports the missing ones DOWN.
EMAIL_INTEL_ACCOUNTS=
# Caps. These are deliberately SEPARATE: cap the SPEND, never the SIGHT.
# Gmail lists newest-first, so a small list cap silently shortens your lookback
# window — mail is never read, and the run still reports success.
EMAIL_INTEL_LIST_MAX=500
EMAIL_INTEL_REASON_MAX=25
# Ignore mail younger than this so triage has had its chance first. Must be
# larger than the gap between your triage and reason cron slots.
EMAIL_INTEL_GRACE_MIN=45
# How far back the reasoner looks. Set several times WIDER than its cadence:
# mail that ages out of this window is never judged and nothing reports it.
EMAIL_INTEL_LOOKBACK=newer_than:7d
# Tier-1 buckets still worth judging despite being filed, JSON ["Prospect"].
EMAIL_INTEL_REASON_LABELS=
# Model tier per pass. Pin these — a bulk classifier must not inherit the
# interactive chat model.
EMAIL_TRIAGE_MODEL=haiku
EMAIL_REASON_MODEL=sonnet
# Digest window, and the age at which a mailbox's heartbeat means PIPELINE DOWN
# (set a little above the digest's own cadence so one skipped run isn't an alarm).
EMAIL_INTEL_DIGEST_HOURS=72
EMAIL_INTEL_STALE_HOURS=26
# Optional Telegram delivery for the digest. Without both, it prints to stdout
# (cron captures it to the log).
EMAIL_INTEL_TELEGRAM_MEMBER=
EMAIL_INTEL_TELEGRAM_CHAT_ID=
# Classify/judge and log, writing nothing — no labels, no rows, no heartbeat.
EMAIL_INTEL_DRYRUN=0

# ---- Sales desk (optional daily ranked call list) ----
# Reads your pipeline and posts a ranked call list, a short priorities brief and
# a hygiene report. READ-ONLY: it never writes to a CRM and never sends email.
# See server/sales_desk.py and INSTALL.md.
#
# Free-text: what you sell, to whom, and what "urgent" means here. Ships EMPTY —
# without it the model ranks confidently and wrongly.
SALES_DESK_CONTEXT=
# Which lead sources to gather from (comma-separated). "pipeline" is built in
# and reads this install's own outbound prospects + their latest engagement.
SALES_DESK_SOURCES=pipeline
# Pipeline stage rules as JSON {status: {callable, weight, terminal}}. Stage
# names are DATA, never control flow — adding a stage is an edit here, not a
# release. An unknown status stays callable so a stage added in your CRM this
# morning shows up rather than vanishing.
SALES_DESK_STATUS_RULES=
# How many leads to show, and the candidate pool ceiling that bounds both tokens
# and the number of model calls.
SALES_DESK_LIST_SIZE=50
SALES_DESK_RANK_MAX=220
# Leads per ranking call. Batch on OUTPUT rows: when you need one output line
# per input line, the model starts dropping rows long before the input runs out,
# and a truncated ranking looks exactly like a complete one.
SALES_DESK_RANK_BATCH=50
# Days without a touch before a lead counts as stale in the hygiene report.
SALES_DESK_STALE_DAYS=21
# Model tier per layer — pinned, so a daily batch never inherits the chat brain.
SALES_DESK_RANK_MODEL=sonnet
SALES_DESK_BRIEF_MODEL=sonnet
# Local-time offset in minutes, used for "today" in the header. Config, never an
# inline offset — a hardcoded one silently reports the wrong day.
SALES_DESK_TZ_OFFSET_MIN=0
# Optional Telegram delivery. Without these the desk prints to stdout.
# OPS_CHAT_ID receives failures; the team channel never sees a stack trace.
SALES_DESK_TELEGRAM_MEMBER=
SALES_DESK_CHAT_ID=
SALES_DESK_OPS_CHAT_ID=

# ---- Opportunity tracker (optional) ----
# Tracks outbound pursuits (job applications, pitches, grants, CFPs) and
# matches replies from your own mailbox back to them. Read-only on mail; it
# never sends anything. See server/opportunity_tracker.py and INSTALL.md.
#
# Days of silence after which a submitted opportunity is worth a nudge. The
# tracker only ever LISTS these — chasing is your call, not a cron's.
OPP_STALE_DAYS=14
# Ask a model about messages the patterns couldn't classify. OFF by default:
# the patterns handle the overwhelming majority, and a tracker that silently
# costs money per inbound message is a bad default.
OPP_LLM_FALLBACK=0
OPP_CLASSIFY_MODEL=haiku
# Match and classify, but write nothing.
OPP_DRYRUN=0
